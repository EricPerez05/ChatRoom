{
  "name": "backend",
  "version": "1.0.0",
  "description": "ChatRoom backend API",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "dist/index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "test": "jest --config jest.config.cjs",
    "test:coverage": "jest --config jest.config.cjs --coverage",
    "test:watch": "jest --config jest.config.cjs --watch",
    "test:vitest": "vitest run",
    "test:jest": "jest --config jest.config.cjs",
    "test:jest:api-controller": "jest --config jest.config.cjs tests/jest/apiController.test.ts",
    "test:jest:question-status-service": "jest --config jest.config.cjs tests/jest/questionStatusService.test.ts"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.15.6",
    "@types/supertest": "^6.0.3",
    "jest": "^30.3.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
